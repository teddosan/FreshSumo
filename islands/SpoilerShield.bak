export default function SpoilerShield({ currentDay }: { currentDay: number }) {
  const updateDay = (day: number) => {
    console.log("Button clicked for day:", day); // <--- DEBUG LINE

    try {
      // 1. Set the cookie
      document.cookie =
        `sumo_watched_day=${day}; path=/; max-age=31536000; SameSite=Lax`;

      console.log("Cookie set to:", document.cookie);

      // 2. Force the reload
      window.location.href = window.location.pathname;
    } catch (e) {
      console.error("Cookie/Reload failed:", e);
    }
  };

  return (
    <div class="grid grid-cols-5 gap-1">
      {Array.from({ length: 15 }, (_, i) => i + 1).map((day) => (
        <button
          type="button" // <--- Ensure it's not trying to submit a form
          onClick={() => updateDay(day)}
          class={`text-[10px] py-1.5 rounded font-bold ${
            currentDay === day
              ? "bg-amber-400 text-indigo-900"
              : "bg-indigo-800"
          }`}
        >
          {day}
        </button>
      ))}
    </div>
  );
}
